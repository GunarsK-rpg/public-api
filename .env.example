# Service Configuration
SERVICE_NAME=public-api
PORT=8182
ENVIRONMENT=development
GIN_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=cosmere_app
DB_PASSWORD=cosmere_app_dev_pass
DB_NAME=cosmere_rpg
DB_SSL_MODE=disable

# JWT Authentication (required - must match auth-service)
JWT_SECRET=your-secret-key-at-least-32-characters

# CORS Configuration
ALLOWED_ORIGINS=https://localhost:8543,http://localhost:8100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_SOURCE=false

# Request Limits
MAX_BODY_SIZE=1048576
